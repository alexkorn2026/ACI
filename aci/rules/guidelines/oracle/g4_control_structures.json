    {"id": "G-4375", "title": "EXIT WHEN statt IF zum Schleifenabbruch", "severity": "Minor", "enabled": false, "coverage": "needs-parser"},
    {"id": "G-4385", "title": "Kein CURSOR FOR LOOP zur reinen Existenzprüfung", "severity": "Major", "enabled": false, "coverage": "needs-parser"},
    {"id": "G-4390", "title": "Keine unreferenzierten FOR-Loop-Indizes", "severity": "Minor", "enabled": false, "coverage": "needs-parser"},
    {"id": "G-4395", "title": "Keine hartkodierten Grenzen bei FOR-Schleifen", "severity": "Minor", "enabled": false, "coverage": "needs-parser"}
  ]
